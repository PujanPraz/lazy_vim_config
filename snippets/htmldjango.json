{
  "block": {
    "prefix": "block",
    "body": ["{% block ${1:name} %}", "  $2", "{% endblock %}"],
    "description": "Django block tag"
  },
  "extends": {
    "prefix": "extends",
    "body": ["{% extends '${1:base.html}' %}"],
    "description": "Django extends tag"
  },
  "include": {
    "prefix": "include",
    "body": ["{% include '${1:template.html}' %}"],
    "description": "Django include tag"
  },
  "for": {
    "prefix": "for",
    "body": ["{% for ${1:item} in ${2:items} %}", "  $3", "{% endfor %}"],
    "description": "Django for loop"
  },
  "if": {
    "prefix": "if",
    "body": ["{% if ${1:condition} %}", "  $2", "{% endif %}"],
    "description": "Django if tag"
  },
  "ifelse": {
    "prefix": "ife",
    "body": ["{% if ${1:condition} %}", "  $2", "{% else %}", "  $3", "{% endif %}"],
    "description": "Django if else tag"
  },
  "url": {
    "prefix": "url",
    "body": ["{% url '${1:name}' %}"],
    "description": "Django url tag"
  },
  "static": {
    "prefix": "static",
    "body": ["{% static '${1:path}' %}"],
    "description": "Django static tag"
  },
  "load": {
    "prefix": "load",
    "body": ["{% load ${1:static} %}"],
    "description": "Django load tag"
  },
  "variable": {
    "prefix": "var",
    "body": ["{{ ${1:variable} }}"],
    "description": "Django variable"
  },
  "comment": {
    "prefix": "comment",
    "body": ["{# ${1:comment} #}"],
    "description": "Django comment"
  },
  "csrf": {
    "prefix": "csrf",
    "body": ["{% csrf_token %}"],
    "description": "Django CSRF token"
  },
  "with": {
    "prefix": "with",
    "body": ["{% with ${1:var}=${2:value} %}", "  $3", "{% endwith %}"],
    "description": "Django with tag"
  }
}
