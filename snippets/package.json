{
  "name": "custom-snippets",
  "engines": {
    "vscode": "^1.0.0"
  },
  "contributes": {
    "snippets": [
      {
        "language": [
          "javascriptreact",
          "typescriptreact"
        ],
        "path": "./jsx.json"
      },
      {
        "language": [
          "python"
        ],
        "path": "./django.json"
      },
      {
        "language": [
          "htmldjango",
          "html"
        ],
        "path": "./htmldjango.json"
      }
    ]
  }
}
